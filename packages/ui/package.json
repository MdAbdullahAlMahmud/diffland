{
  "name": "@diffland/ui",
  "version": "0.0.0",
  "description": "React views and components for diffland (Village, Blast, Orbit, …).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
