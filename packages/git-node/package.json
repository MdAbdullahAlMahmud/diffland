{
  "name": "@diffland/git-node",
  "version": "0.0.0",
  "description": "Node.js GitProvider + FsProvider implementation for diffland.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -b --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@diffland/core": "workspace:*",
    "simple-git": "^3.27.0",
    "fast-glob": "^3.3.2"
  }
}
